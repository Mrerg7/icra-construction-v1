---
import {
  SITE_URL,
  SITE_NAME,
  HERO_IMAGE_URL,
  ACQUISITION_EMAIL,
} from '../lib/constants';

const description =
  'icra.construction — The direct .construction domain for specialized healthcare construction and renovation with deep ICRA expertise. The perfect brand for contractors who protect patients during building.';

const webPage = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${SITE_NAME} — Premium Domain for ICRA Construction | Healthcare Builders`,
  description,
  url: SITE_URL,
  inLanguage: 'en-US',
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: HERO_IMAGE_URL,
    contentUrl: HERO_IMAGE_URL,
  },
  about: {
    '@type': 'Thing',
    name: 'Infection Control Risk Assessment (ICRA) Construction Domain',
    description:
      'Premium .construction domain name asset for specialized healthcare construction and renovation with ICRA expertise.',
  },
};

const organization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE_NAME,
  url: SITE_URL,
  email: ACQUISITION_EMAIL,
  logo: HERO_IMAGE_URL,
  description,
};

const product = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'icra.construction domain name',
  description:
    'Premium .construction domain for specialized healthcare construction with ICRA expertise. The direct brand for contractors who master Infection Control Risk Assessment in occupied facilities.',
  category: 'Domain Name',
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    price: '14997',
    priceCurrency: 'USD',
    seller: {
      '@type': 'Organization',
      email: ACQUISITION_EMAIL,
    },
    url: `mailto:${ACQUISITION_EMAIL}`,
    shippingDetails: {
      '@type': 'OfferShippingDetails',
      shippingRate: {
        '@type': 'MonetaryAmount',
        value: '0.00',
        currency: 'USD',
      },
      deliveryTime: {
        '@type': 'ShippingDeliveryTime',
        handlingTime: {
          '@type': 'QuantitativeValue',
          minValue: 0,
          maxValue: 1,
          unitCode: 'DAY',
        },
        transitTime: {
          '@type': 'QuantitativeValue',
          minValue: 0,
          maxValue: 0,
          unitCode: 'DAY',
        },
      },
      shippingDestination: {
        '@type': 'DefinedRegion',
        addressCountry: 'US',
      },
    },
    hasMerchantReturnPolicy: {
      '@type': 'MerchantReturnPolicy',
      returnPolicyCategory: 'https://schema.org/MerchantReturnFiniteReturnWindow',
      returnMethod: 'https://schema.org/ReturnByMail',
      returnFees: 'https://schema.org/FreeReturn',
      applicableCountry: 'US',
      merchantReturnDays: 0,
    },
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(webPage)} />
<script type="application/ld+json" set:html={JSON.stringify(organization)} />
<script type="application/ld+json" set:html={JSON.stringify(product)} />
